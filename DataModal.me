## 3.4 `requests` (base parent schema with discriminator key)

```ts
{
  _id: ObjectId,
  requestNo: string,                 // unique generated id
  requestType: REQUEST_TYPES[number],// discriminator key
  routingType: ROUTING_TYPES[number],

  requestorId: ObjectId,             // ref users
  companyId: ObjectId,               // ref companies
  projectId: ObjectId,               // ref projects
  projectCodeSnapshot: string,       // keep historical value

  status: REQUEST_STATUS[number],    // New / Verified / Rework / R / FR / Closed
  engagementRound: number,           // 0 by default; if status=R then 1..n
  reviewCode: REVIEW_CODES[number],  // 1/2/3/4/W
  outcomeCode: OUTCOME_CODES[number],// ACK/E/FA/RS/NC/NC3/NC4/W

  acknowledgement: boolean,          // must be true on final submit

  files: [{
    fileName: string,
    url: string,
    mimeType: string,
    sizeBytes: number,
    cloudinaryId?: string,
    uploadedBy: ObjectId,
    uploadedAt: Date
  }],

  // key process timestamps
  timeline: {
    submittedAt?: Date,
    verifiedAt?: Date,
    engagementScheduledAt?: Date,
    engagementCompletedAt?: Date,
    summaryReportSignedAt?: Date,
    acceptanceSignedAt?: Date,
    ackLetterGeneratedAt?: Date,
    endorsementLetterGeneratedAt?: Date
  },

  // SLA tracking per active stage
  sla: {
    stage?: string,
    thresholdHours?: number,
    startedAt?: Date,
    dueAt?: Date,
    breachedAt?: Date,
    isViolated: boolean
  },

  isDeleted: boolean,
  createdAt: Date,
  updatedAt: Date
}
```

Indexes:
- `{ requestNo: 1 } unique`
- `{ requestType: 1, routingType: 1 }`
- `{ requestorId: 1, createdAt: -1 }`
- `{ companyId: 1, projectId: 1, createdAt: -1 }`
- `{ status: 1, outcomeCode: 1 }`
- `{ "sla.isViolated": 1, updatedAt: -1 }`

