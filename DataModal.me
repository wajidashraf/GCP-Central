  companyName: string,
  sector: string,
  createdAt: Date,
  updatedAt: Date
}
```

## 3.3 `projects`

```ts
{
  _id: ObjectId,
  companyId: ObjectId,         // ref companies
  projectCode: string,         // unique
  projectName: string,
  clientName?: string,
  projectStatus: "Inactive" | "Active" | "Completed" | "Dead",
