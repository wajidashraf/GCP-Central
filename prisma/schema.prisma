generator client {
  provider = "prisma-client-js"
}

model Role {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String
  emailLower    String   @unique
  username      String
  usernameLower String   @unique
  passwordHash  String
  primaryRole   String
  roles         String[]
  companyId     String?  @db.ObjectId
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([primaryRole])
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model Company {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  companyName String
  companyCode String   @unique
  sector      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requests Request[]
  projects Project[]
  users    User[]
}

model Request {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  requestNo       String    @unique
  requestType     String
  routingType     String
  requestTitle    String
  category        String
  requestorId     String
  requestorName   String
  requestorEmail  String
  companyId       String    @db.ObjectId
  companyCode     String
  companyName     String
  status          String    @default("Draft")
  acknowledgement Boolean   @default(false)
  submittedAt     DateTime?
  verifierCommentText String?
  verifierDecisionCode String?
  verifiedBy      String?
  verifiedAt      DateTime?
  reviewConclusionCode1a     Boolean   @default(false)
  reviewConclusionCode1b     Boolean   @default(false)
  reviewConclusionCode1bComment String?
  reviewConclusionCode2      Boolean   @default(false)
  reviewConclusionCode3      Boolean   @default(false)
  reviewConclusionCode4      Boolean   @default(false)
  hocReviewAcceptanceSignUrl        String?
  hocReviewAcceptanceSignPublicId   String?
  hocReviewAcceptanceSignedAt       DateTime?
  hocReviewAcceptanceSignerUserId   String?   @db.ObjectId
  ackLetterTextContent              String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company              Company              @relation(fields: [companyId], references: [id])
  rtp                  RtpRequest?
  pbl                  PblRequest?
  jvp                  JvpRequest?
  rpp                  RppRequest?
  projects             Project[]
  verifierComment      VerifierComment?
  reviewerSuggestions  ReviewerSuggestion[]
  engagements          Engagement[]
  signatures           RequestSignature[]

  @@index([requestType, routingType])
  @@index([requestorEmail])
  @@index([companyId])
}

model Project {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId            String   @db.ObjectId
  companyCode          String
  companyName          String
  projectStatus        String   @default("Inactive")
  projectName          String
  projectCode          String?
  createdFromRequestId String?  @db.ObjectId
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company     Company      @relation(fields: [companyId], references: [id])
  request     Request?     @relation(fields: [createdFromRequestId], references: [id])
  rtpRequests RtpRequest[]
  pblRequests PblRequest[]
  jvpRequests JvpRequest[]
  rppRequests RppRequest[]

  @@index([companyId])
  @@index([createdFromRequestId])
  @@index([projectStatus])
  @@index([projectName])
  @@index([projectCode])
}

model RtpRequest {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  requestId          String    @unique @db.ObjectId
  clientName         String
  registrationType   Int
  tenderClosingDate  DateTime?
  projectName        String
  projectDescription String
  specialProject     Boolean   @default(false)
  documentUrl        String?
  documentPublicId   String?
  documentFileName   String?
  documentMimeType   String?
  documentSizeBytes  Int?
  projectId          String?   @db.ObjectId
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  request Request  @relation(fields: [requestId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([projectName])
}

model PblRequest {
  id                          String   @id @default(auto()) @map("_id") @db.ObjectId
  requestId                   String   @unique @db.ObjectId
  projectId                   String   @db.ObjectId
  projectCode                 String?
  procurementMethod           Int
  justificationForLessBidders String?
  documentUrl                 String?
  documentPublicId            String?
  documentFileName            String?
  documentMimeType            String?
  documentSizeBytes           Int?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  request Request     @relation(fields: [requestId], references: [id])
  project Project     @relation(fields: [projectId], references: [id])
  bidders PblBidder[]

  @@index([projectId])
  @@index([procurementMethod])
}

model JvpRequest {
  id                          String   @id @default(auto()) @map("_id") @db.ObjectId
  requestId                   String   @unique @db.ObjectId
  projectId                   String   @db.ObjectId
  projectCode                 String?
  teamLeader                  String?
  financialMatters            String?
  technicalMatters            String?
  contractMatters             String?
  procurementMatters          String?
  costingAndEstimationMatters String?
  implementationStage         String?
  backgroundOfCollabPoints    Json?
  scopeOfCollabPoints         Json?
  proposedStructurePoints     Json?
  keyTermsPoints              Json?
  financialOverviewPoints     Json?
  technicalCapabilitiesPoints Json?
  workPackagesDivisionPoints  Json?
  resourcesContributionPoints Json?
  riskReviewMitigationItems   Json?
  cashflowForecastUrl         String?
  cashflowForecastPublicId    String?
  cashflowForecastFileName    String?
  cashflowForecastMimeType    String?
  cashflowForecastSizeBytes   Int?
  costStructureUrl            String?
  costStructurePublicId       String?
  costStructureFileName       String?
  costStructureMimeType       String?
  costStructureSizeBytes      Int?
  documentUrl                 String?
  documentPublicId            String?
  documentFileName            String?
  documentMimeType            String?
  documentSizeBytes           Int?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  request Request @relation(fields: [requestId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model RppRequest {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  requestId         String   @unique @db.ObjectId
  projectId         String   @db.ObjectId
  projectCode       String?
  documentUrl       String?
  documentPublicId  String?
  documentFileName  String?
  documentMimeType  String?
  documentSizeBytes Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  request Request @relation(fields: [requestId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model PblBidder {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  pblRequestId     String   @db.ObjectId
  companyName      String
  location         String?
  personInCharge   String
  picContactNumber String
  sourcesFrom      String
  recommendationBy String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  pblRequest PblRequest @relation(fields: [pblRequestId], references: [id])

  @@index([pblRequestId])
  @@index([companyName])
}

model VerifierComment {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  requestId     String   @unique @db.ObjectId
  verifierId    String   @db.ObjectId
  comment       String
  decisionCode  String
  verifiedBy    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([verifierId])
}

model ReviewerSuggestion {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  requestId String   @db.ObjectId
  reviewerId String  @db.ObjectId
  reviewerName String?
  suggestion String
  sourceRole String?
  status    String   @default("pending")
  action    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([reviewerId])
  @@index([sourceRole])
}

model EngagementSlot {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  slotName  String
  startTime DateTime
  endTime   DateTime
  attendees String[]
  location  String?
  status    String?  @default("available")
  createdBy String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagements Engagement[]

  @@index([status])
  @@index([createdBy])
}

model Engagement {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  requestId String   @db.ObjectId
  slotId    String   @db.ObjectId
  requestorId String @db.ObjectId
  engagementNumber String?
  name      String?
  type      String?
  location  String?
  status    String   @default("scheduled")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request Request         @relation(fields: [requestId], references: [id], onDelete: Cascade)
  slot    EngagementSlot @relation(fields: [slotId], references: [id])

  @@index([requestId])
  @@index([engagementNumber])
  @@index([slotId])
  @@index([requestorId])
}

model SignatoryMember {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  group      String
  name       String
  email      String
  emailLower String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  signatures RequestSignature[]

  @@index([group])
  @@index([emailLower])
}

model RequestSignature {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  requestId           String   @db.ObjectId
  signatoryMemberId   String   @db.ObjectId
  signatoryName       String
  signatoryEmail      String
  signatoryEmailLower String
  type                String
  signUrl             String
  signPublicId        String?
  signedAt            DateTime @default(now())
  signerUserId        String   @db.ObjectId
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  request Request         @relation(fields: [requestId], references: [id], onDelete: Cascade)
  member  SignatoryMember @relation(fields: [signatoryMemberId], references: [id])

  @@unique([requestId, signatoryMemberId])
  @@index([requestId])
  @@index([type])
  @@index([signatoryMemberId])
}
